# Supabase 接続情報
# Supabase ダッシュボード → Settings → API から取得
# .env.local にコピーして実際の値を入れる（.env.local はコミットしない）

NEXT_PUBLIC_SUPABASE_URL=https://nowgseppuovwfixrvtti.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# サーバーサイドでのみ使う（絶対にクライアントに露出させない）
# 管理画面の高権限操作で使用
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
